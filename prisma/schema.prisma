// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Transactional Email App ──────────────────────────────────────────────────

// Reusable email templates with placeholders like {{name}}, {{email}}
model Template {
  id           String      @id @default(cuid())
  name         String                     // e.g. "Welcome Email"
  description  String?                    // short note about when to use
  senderName   String
  senderEmail  String
  subject      String
  bodyTemplate String      @db.Text
  emails       SentEmail[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([createdAt])
}

// Each individual email that was sent
model SentEmail {
  id                String    @id @default(cuid())
  templateId        String?
  template          Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  toName            String
  toEmail           String
  replyTo           String?
  subject           String
  body              String    @db.Text
  provider          String    @default("smtp")
  providerMessageId String?
  replies           InboundEmail[]
  status            String    @default("sent") // sent | failed | delivered | opened | clicked | bounced
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([templateId])
  @@index([toEmail])
  @@index([status])
  @@index([createdAt])
}

// Inbound emails received in Gmail inbox (replies/new messages)
model InboundEmail {
  id          String    @id @default(cuid())
  gmailId     String    @unique           // Gmail message ID (deduplication)
  threadId    String?                     // Gmail thread ID
  sentEmailId String?                     // linked outbound email if matched
  sentEmail   SentEmail? @relation(fields: [sentEmailId], references: [id], onDelete: SetNull)
  fromName    String
  fromEmail   String
  toEmail     String
  subject     String
  bodyText    String?   @db.Text
  bodyHtml    String?   @db.Text
  snippet     String?                     // Gmail short preview
  isRead      Boolean   @default(false)
  receivedAt  DateTime
  createdAt   DateTime  @default(now())

  @@index([fromEmail])
  @@index([isRead])
  @@index([receivedAt])
  @@index([sentEmailId])
}

// Simple key-value store for runtime app settings (e.g. active email provider)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

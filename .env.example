# Database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Microsoft Graph API (send + receive via Outlook / Microsoft 365) ──────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-app-client-secret

# Mailbox to send from and read inbox (must have Mail.Send + Mail.Read permissions)
AZURE_INBOX_EMAIL=hr-notify@yourdomain.com
MAIL_FROM_ADDRESS=hr-notify@yourdomain.com
MAIL_FROM_NAME="Your Company Helpdesk"

# App URL
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

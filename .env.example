# Database
DATABASE_URL="postgresql://user:password@localhost:5432/email_app"

# Email provider: resend | microsoft
EMAIL_PROVIDER="resend"

# --- Resend ---
RESEND_API_KEY="re_your_resend_api_key_here"
# From address Resend will use (must be allowed by your Resend account).
# - Quick test: onboarding@resend.dev (only delivers to your Resend account email)
# - Production: an address on a domain you add at https://resend.com/domains
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_WEBHOOK_SECRET="whsec_tMe5zqSVtY+HhOaU7ohX989UPe+u/n/F"

# Alias for RESEND_FROM_EMAIL (either may be set)
# EMAIL_FROM="noreply@your-verified-domain.com"

# --- Microsoft Graph (when EMAIL_PROVIDER=microsoft) ---
# App registration: client credentials + application permission Mail.Send (admin consent)
AZURE_TENANT_ID="your-tenant-id"
AZURE_CLIENT_ID="your-app-client-id"
AZURE_CLIENT_SECRET="your-app-client-secret"
# Mailbox to send as (user principal name), e.g. noreply@tanseeqinvestment.com
MS_GRAPH_MAILBOX="noreply@tanseeqinvestment.com"

# --- Gmail Inbox Sync OAuth (reply fetching) ---
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
# Optional fallback token if DB token is not connected yet
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"
# Mailbox to treat as "us" for inbox filtering
GOOGLE_INBOX_EMAIL="you@gmail.com"
# Recommended: encrypt DB-stored Gmail refresh token
GOOGLE_TOKEN_ENCRYPTION_KEY="set-a-long-random-secret"

# Optional
NEXT_PUBLIC_APP_URL="http://localhost:3000"
